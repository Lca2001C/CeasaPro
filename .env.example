# ─────────── App ───────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────── Banco de dados (PostgreSQL) ───────────
# Em produção (Neon), use a URL "pooled" em DATABASE_URL e a "direct" em DIRECT_URL.
# Em desenvolvimento local, as duas podem ser iguais.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ceasapro?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ceasapro?schema=public"

# ─────────── Autenticação (jose) ───────────
# Gere segredos fortes: openssl rand -base64 32
JWT_ACCESS_SECRET="troque-por-um-segredo-de-32+bytes"
JWT_REFRESH_SECRET="troque-por-outro-segredo-de-32+bytes"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# ─────────── Seed do super-admin ───────────
SEED_SUPERADMIN_EMAIL="admin@ceasapro.com.br"
SEED_SUPERADMIN_PASSWORD="troque-no-primeiro-login"  # obrigatorio; sem valor padrao no codigo
SEED_DEMO="false"
# SEED_DEMO_PASSWORD="demo123"  # opcional; senha da empresa de exemplo (default: demo123)

# ─────────── Mercado Pago ───────────
MP_ACCESS_TOKEN="APP_USR-xxxxxxxx"
MP_PUBLIC_KEY="APP_USR-pub-xxxxxxxx"
# Public key exposta ao browser (Card Brick). Precisa do prefixo NEXT_PUBLIC_.
# Sem segredo (é pública), mas precisa existir no build client (setar também na Vercel/CI).
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-pub-xxxxxxxx"
MP_WEBHOOK_SECRET="assinatura-secreta-do-painel-mercado-pago"

# ─────────── E-mail transacional (Resend) ───────────
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="CeasaPro <nao-responda@ceasapro.com.br>"

# ─────────── Cron (recálculo/geração de cobrança) ───────────
CRON_SECRET="token-para-proteger-/api/cron/billing"

# ─────────── Storage (Cloudflare R2) — logo/anexos (opcional) ───────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""
